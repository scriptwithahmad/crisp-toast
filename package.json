{
  "name": "crisp-toast",
  "version": "1.0.6",
  "description": "A lightweight, beautiful, and highly customizable vanilla JS toast notification library.",
  "type": "module",
  "main": "./dist/crisp-toast.umd.cjs",
  "module": "./dist/crisp-toast.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/crisp-toast.js",
      "require": "./dist/crisp-toast.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "toast",
    "toast-notification",
    "notification",
    "javascript-toast",
    "vanilla-js",
    "alert",
    "toast-library",
    "ui-library",
    "frontend",
    "crisp-toast"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/scriptwithahmad/crisp-toast.git"
  },
  "homepage": "https://github.com/scriptwithahmad/crisp-toast#readme",
  "bugs": {
    "url": "https://github.com/scriptwithahmad/crisp-toast/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "author": "Ahmad",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  }
}
